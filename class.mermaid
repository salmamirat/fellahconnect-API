classDiagram

class Role {
  +id : Integer
  +nom : String
}

class User {
  +id : Integer
  +name : String
  +email : String
  +password : String
  +roleId : Integer
}

class Agriculteur {
  +id : Integer
  +nom : String
  +telephone : String
  +region : String
  +userId : Integer
}

class Parcelle {
  +id : Integer
  +nom : String
  +superficie : Float
  +region : String
  +agriculteurId : Integer
}

class Produit {
  +id : Integer
  +nom : String
  +categorie : String
  +unite : String
}

class Recolte {
  +id : Integer
  +quantite : Float
  +dateRecolte : Date
  +parcelleId : Integer
  +produitId : Integer
}

class Marche {
  +id : Integer
  +nom : String
  +ville : String
  +region : String
}

class PrixMarche {
  +id : Integer
  +prix : Float
  +datePrix : Date
  +produitId : Integer
  +marcheId : Integer
}

class OffreVente {
  +id : Integer
  +quantite : Float
  +prixSouhaite : Float
  +statut : String
  +recolteId : Integer
}

Role "1" --> "0..*" User : has

User "1" --> "1" Agriculteur : profile

Agriculteur "1" --> "0..*" Parcelle : owns

Parcelle "1" --> "0..*" Recolte : produces

Produit "1" --> "0..*" Recolte : harvested

Produit "1" --> "0..*" PrixMarche : priced

Marche "1" --> "0..*" PrixMarche : records

Recolte "1" --> "0..*" OffreVente : offered