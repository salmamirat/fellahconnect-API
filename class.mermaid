
classDiagram

class Utilisateur {
  +id : Integer
  +nom : String
  +email : String
  +password : String
  +role : String
}

class Agriculteur {
  +id : Integer
  +telephone : String
  +region : String
  +utilisateurId : Integer
}

class Parcelle {
  +id : Integer
  +nom : String
  +surface : Float
  +ville : String
  +agriculteurId : Integer
}

class Recolte {
  +id : Integer
  +quantite : Float
  +date : Date
  +parcelleId : Integer
  +produitId : Integer
}

class Produit {
  +id : Integer
  +nom : String
  +categorie : String
}

class PrixMarche {
  +id : Integer
  +prix : Decimal
  +date : Date
  +produitId : Integer
  +marcheId : Integer
}

class Marche {
  +id : Integer
  +nom : String
  +ville : String
}

class Offre {
  +id : Integer
  +quantite : Float
  +prix : Decimal
  +statut : String
  +recolteId : Integer
}

Utilisateur "1" --> "1" Agriculteur

Agriculteur "1" --> "*" Parcelle

Parcelle "1" --> "*" Recolte

Produit "1" --> "*" Recolte

Produit "1" --> "*" PrixMarche

Marche "1" --> "*" PrixMarche

Recolte "1" --> "1" Offre
